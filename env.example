# ─── App URL (Frames + Cast Action links) ────────────────────────────
# Production / preview: set to your stable https origin (Vercel: use the deployment
# hostname or your production domain). Warpcast loads Frames from this host.
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# ─── Alchemix V3 ─────────────────────────────────────────────────────
# Feature flag — set to true to enable V3 UI (always true in production)
NEXT_PUBLIC_ENABLE_ALCHEMIX_V3=true

# Default chain shown on first load — users can switch Mainnet/Sepolia in the UI.
NEXT_PUBLIC_ALCHEMIX_V3_CHAIN_ID=11155111

# Mainnet V3 config
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_ALCHEMIST_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_POSITION_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_TRANSMUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_DEBT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_UNDERLYING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MAINNET_MYT_ADDRESS=0x0000000000000000000000000000000000000000

# Sepolia V3 config
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_ALCHEMIST_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_POSITION_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_TRANSMUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_DEBT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_UNDERLYING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_SEPOLIA_MYT_ADDRESS=0x0000000000000000000000000000000000000000

# Legacy single-chain fallback, used only when chain-specific values are absent.
NEXT_PUBLIC_ALCHEMIX_V3_ALCHEMIST_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_POSITION_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_TRANSMUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_DEBT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_UNDERLYING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MYT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_RPC_URL=https://rpc.sepolia.org

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# RPC URLs (used by network config and wallet transports)
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SEPOLIA_RPC_URL=https://rpc.sepolia.org

