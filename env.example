# ─── Alchemix V3 ─────────────────────────────────────────────────────
# Feature flag — set to true to enable V3 UI (always true in production)
NEXT_PUBLIC_ENABLE_ALCHEMIX_V3=true

# Adapter mode: "mock" for local dev, "contracts" for live on-chain
NEXT_PUBLIC_ALCHEMIX_V3_MODE=mock

# Target chain — 1 = ETH mainnet, 11155111 = Sepolia, 42161 = Arbitrum, 10 = Optimism
NEXT_PUBLIC_ALCHEMIX_V3_CHAIN_ID=1
NEXT_PUBLIC_ALCHEMIX_V3_RPC_URL=https://eth.llamarpc.com

# V3 Contract Addresses
# ⚠️ Verify against official Alchemix governance before production use.
NEXT_PUBLIC_ALCHEMIX_V3_ALCHEMIST_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_POSITION_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_TRANSMUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_DEBT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_UNDERLYING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ALCHEMIX_V3_MYT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# RPC URLs (used by network config and wallet transports)
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Known V3 Deployment References (from broadcast files, for documentation only):
#   VaultV2Factory:             0xdd56b00302e91c4c2b8246156bdeaa1cedc58984
#   VaultV2 (USDC underlying):  0x9b44efca3e2a707b63dc00ce79d646e5e5d24ba5
#   VaultV2 (WETH underlying):  0x29bcfed246ce37319d94eba107db90c453d4c43d
#   AlchemistCurator:           0x7d61e3cde8b58c4be192a7a35e9d626c419302a4
#   StrategyClassifier:         0xdb7d25b0bfd1585a797f6bf7d7ccba26e77253cc
